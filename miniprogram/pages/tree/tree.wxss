.page-tree { min-height: 100vh; background: #f5f0eb; padding-bottom: 120rpx; }
.page-tree.theme-celadon { background: #edf1f0; }

.tree-header {
  background: #8B4513;
  color: white;
  padding: 40rpx 32rpx 32rpx;
  border-radius: 0 0 40rpx 40rpx;
  margin-bottom: 24rpx;
}
.theme-celadon .tree-header {
  background: linear-gradient(180deg, #1a4a40 0%, #2a6b5b 100%);
}
.tree-title { display: block; font-size: 44rpx; font-weight: bold; }
.tree-count { display: block; font-size: 26rpx; opacity: 0.85; margin-top: 8rpx; }
.header-actions { display: flex; align-items: center; justify-content: space-between; margin-top: 20rpx; }
.view-switch { display: flex; gap: 20rpx; font-size: 26rpx; }
.view-switch text { opacity: 0.65; padding: 8rpx 24rpx; border-radius: 30rpx; }
.view-switch text.active { background: rgba(255,255,255,0.22); opacity: 1; }
.btn-manage { font-size: 26rpx; background: rgba(255,255,255,0.2); padding: 8rpx 28rpx; border-radius: 30rpx; }
.loading { text-align: center; padding: 80rpx; color: #999; }

/* 垂直世系 */
.vtree-wrap { padding: 0 24rpx 32rpx; }
.vtree-legend {
  font-size: 24rpx;
  color: #666;
  line-height: 1.55;
  margin: 0 0 28rpx;
  padding: 24rpx 28rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #e8e0d8;
}
.vertical-tree {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 0 24rpx;
}
.vt-level { width: 100%; max-width: 620rpx; text-align: center; }
.vt-rank {
  font-size: 22rpx;
  font-weight: 700;
  color: #888;
  margin-bottom: 20rpx;
  letter-spacing: 0.12em;
}
.vt-nodes {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
}
.vt-nodes.vt-pair { gap: 12rpx 20rpx; }
.vt-mate { font-size: 20rpx; color: #bbb; letter-spacing: 0.2em; }
.vt-node {
  border: 2rpx solid #e8e0d8;
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #333;
  max-width: 280rpx;
  line-height: 1.45;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.vt-node.vt-root {
  border: 4rpx solid #8B4513;
  color: #8B4513;
  font-weight: 700;
}
.vt-node.vt-spouse {
  background: #f0e8df;
  color: #666;
  font-size: 26rpx;
}
.vt-name { font-weight: 600; }
.vt-gen {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  font-weight: normal;
}
.badge-me {
  display: inline-block;
  margin-left: 8rpx;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  background: rgba(139, 69, 19, 0.12);
  color: #8B4513;
  border-radius: 8rpx;
  font-weight: 700;
}
.vt-stem {
  width: 6rpx;
  height: 44rpx;
  margin: 8rpx auto;
  border-radius: 4rpx;
  background: linear-gradient(180deg, #8B4513 0%, rgba(139, 69, 19, 0.22) 100%);
  opacity: 0.8;
}
.vt-stem.short { height: 30rpx; }

/* 列表视图 */
.list-view { padding: 0 30rpx; }
.list-item {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  border-left: 6rpx solid #8B4513;
}
.list-item-indent { margin-left: 16rpx; }
.list-item-spouse { border-left-color: #d4a574; opacity: 0.95; }
.list-indent-bar { color: #ddd; font-size: 24rpx; }

.card-avatar.tiny {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #e8d5c4;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  flex-shrink: 0;
  overflow: hidden;
}
.avatar-img { width: 100%; height: 100%; object-fit: cover; }
.avatar-deceased { filter: grayscale(100%); }

.member-name { font-size: 30rpx; font-weight: bold; color: #333; flex: 1; min-width: 0; }
.member-gen { font-size: 24rpx; color: #999; background: #f5f0eb; padding: 4rpx 16rpx; border-radius: 16rpx; }
.status-alive { font-size: 26rpx; color: #166534; }
.status-deceased { font-size: 26rpx; color: #78716c; }

.empty { text-align: center; padding: 100rpx 40rpx; color: #999; }
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 40rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: white;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
}
.btn-add {
  background: #8B4513;
  color: white;
  border-radius: 50rpx;
  font-size: 32rpx;
}
.btn-add::after { border: none; }

/* 青黛：世系线、根节点、底栏按钮 */
.theme-celadon .vt-node.vt-root {
  border-color: #2a6b5b !important;
  color: #2a6b5b !important;
}
.theme-celadon .vt-stem,
.theme-celadon .vt-fork::before,
.theme-celadon .vt-fork::after {
  background: #2a6b5b !important;
  opacity: 0.55;
}
.theme-celadon .btn-add {
  background: #2a6b5b;
}
.theme-celadon .list-item-mp .member-gen {
  color: #2a6b5b;
}
