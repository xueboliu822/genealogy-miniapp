<view class="container">
  <view class="tree-header">
    <text class="tree-title">{{family_name || '族谱'}}</text>
    <text class="tree-count">{{members.length}} 位成员</text>
  </view>

  <!-- 世代表 -->
  <view wx:for="{{generations}}" wx:key="gen" class="generation-block">
    <view class="gen-label">第{{item.gen}}代</view>
    <view class="gen-members">
      <view wx:for="{{item.members}}" wx:key="id" class="member-chip" bindtap="onMemberTap" data-id="{{item.id}}">
        <text class="member-gender">{{item.gender === 'M' ? '👨' : item.gender === 'F' ? '👩' : '👤'}}</text>
        <text class="member-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{members.length === 0 && !loading}}" class="empty">
    <text>暂无成员，快去添加吧</text>
  </view>

  <!-- 底部添加按钮 -->
  <view class="bottom-bar">
    <button class="btn-add" bindtap="onAddMember">+ 添加成员</button>
  </view>
</view>
