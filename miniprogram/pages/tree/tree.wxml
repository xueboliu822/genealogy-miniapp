<view class="page-tree">
  <view class="tree-header">
    <text class="tree-title">{{family_name || '族谱'}}</text>
    <text class="tree-count">{{members}} 位成员</text>
    <view class="header-actions">
      <view class="view-switch">
        <text class="{{viewMode === 'tree' ? 'active' : ''}}" bindtap="onViewModeChange" data-mode="tree">世系</text>
        <text class="{{viewMode === 'list' ? 'active' : ''}}" bindtap="onViewModeChange" data-mode="list">列表</text>
      </view>
      <text class="btn-manage" bindtap="onManageFamily">管理</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <!-- 垂直世系：按代际分行，同代内为 DFS 顺序（主支 + 配偶 + …） -->
  <block wx:if="{{viewMode === 'tree' && !loading}}">
    <view wx:if="{{verticalLevels.length === 0}}" class="empty">
      <text>暂无世系数据</text>
    </view>
    <view wx:else class="vtree-wrap">
      <view class="vtree-legend">自上而下为代际；「配」后为配偶。点击节点查看详情。</view>
      <view class="vertical-tree">
        <block wx:for="{{verticalLevels}}" wx:for-item="level" wx:for-index="lvlIdx" wx:key="generation_num">
          <view class="vt-level">
            <view class="vt-rank">{{level.rankLabel}}</view>
            <view class="vt-nodes {{level.hasPair ? 'vt-pair' : ''}}">
              <block wx:for="{{level.members}}" wx:for-item="m" wx:for-index="mi" wx:key="id">
                <text class="vt-mate" wx:if="{{m._rowRole === 'spouse'}}">配</text>
                <view
                  class="vt-node {{level.isFirstGen && mi === 0 ? 'vt-root' : ''}} {{m._rowRole === 'spouse' ? 'vt-spouse' : ''}}"
                  bindtap="onMemberTap"
                  data-id="{{m.id}}"
                >
                  <text class="vt-name">{{m.name}}</text>
                  <text wx:if="{{m.is_me}}" class="badge-me">我</text>
                  <text wx:if="{{m.generation_name}}" class="vt-gen">{{m.generation_name}}</text>
                </view>
              </block>
            </view>
          </view>
          <view wx:if="{{lvlIdx < verticalLevels.length - 1}}" class="vt-stem {{lvlIdx === 0 ? '' : 'short'}}"></view>
        </block>
      </view>
    </view>
  </block>

  <block wx:if="{{viewMode === 'list' && !loading}}">
    <view class="list-view">
      <view wx:for="{{flatListData}}" wx:key="{{item.id}}" class="list-item {{item.isSpouse ? 'list-item-spouse' : ''}} {{item.depth > 0 ? 'list-item-indent' : ''}}" bindtap="onMemberTap" data-id="{{item.id}}">
        <text class="list-indent-bar" wx:if="{{item.depth > 0}}">{{item.depth > 0 ? '  ' : ''}}</text>
        <view class="card-avatar tiny {{item.is_alive ? '' : 'avatar-deceased'}}">
          <image wx:if="{{item.avatar_url}}" src="{{item.avatar_url}}" mode="aspectFill" class="avatar-img" />
          <text wx:else>{{item.gender === 'M' ? '男' : item.gender === 'F' ? '女' : '其他'}}</text>
        </view>
        <text class="member-name">{{item.name}}{{item.isSpouse ? '（配）' : ''}}</text>
        <text class="member-gen">第{{item.generation_num}}代</text>
        <text class="{{item.is_alive ? 'status-alive' : 'status-deceased'}}">{{item.is_alive ? '在世' : '已故'}}</text>
      </view>
    </view>
  </block>

  <view wx:if="{{(members === 0 || !treeData || treeData.length === 0) && !loading}}" class="empty">
    <text>暂无成员，快去添加吧</text>
  </view>

  <view class="bottom-bar">
    <button class="btn-add" bindtap="onAddMember">+ 添加成员</button>
  </view>
</view>
