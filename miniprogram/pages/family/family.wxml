<view class="page-root">
  <!-- 对齐 V2 原型：棕色顶栏 + Tab 嵌入顶栏 -->
  <view class="family-head">
    <view class="family-head-text">
      <text class="family-title">{{family_name || '家族'}}</text>
      <text class="family-sub">档案与宗族动态</text>
    </view>
    <view class="tabs-in-head">
      <view class="tab {{tab === 'info' ? 'active' : ''}}" bindtap="onTabChange" data-tab="info">基本信息</view>
      <view class="tab {{tab === 'donations' ? 'active' : ''}}" bindtap="onTabChange" data-tab="donations">捐献榜单</view>
      <view class="tab {{tab === 'activities' ? 'active' : ''}}" bindtap="onTabChange" data-tab="activities">家族活动</view>
    </view>
  </view>

  <!-- 基本信息 -->
  <block wx:if="{{tab === 'info'}}">
    <view class="panel">
      <view class="field">
        <text class="label">堂号</text>
        <input class="input" placeholder="如：亲睦堂" value="{{hall_name}}" bindinput="onHallNameInput" />
      </view>
      <view class="field">
        <text class="label">祠堂位置</text>
        <textarea class="textarea" placeholder="祠堂所在位置" value="{{hall_location}}" bindinput="onHallLocationInput" />
      </view>
      <view class="field">
        <text class="label">迁徙源流</text>
        <textarea class="textarea" placeholder="迁徙与源流简述" value="{{migration_note}}" bindinput="onMigrationNoteInput" />
      </view>
      <view class="field">
        <text class="label">字辈诗</text>
        <textarea class="textarea tall" placeholder="字辈诗，逗号或句读分隔" value="{{generation_poem}}" bindinput="onGenerationPoemInput" />
      </view>
      <button class="btn-primary" bindtap="onSaveHall">保存信息</button>

      <view class="bind-card">
        <text class="bind-title">微信绑定</text>
        <block wx:if="{{boundPerson}}">
          <text class="bind-line">已绑定 <text class="em">{{boundPerson.name}}</text> · {{boundPerson.genLine}}</text>
          <view class="bind-actions">
            <button class="btn-bind ghost" bindtap="onBindHint">更换说明</button>
            <button class="btn-bind danger" bindtap="onUnbind">解绑</button>
          </view>
        </block>
        <block wx:else>
          <text class="bind-line muted">尚未绑定谱员节点</text>
          <button class="btn-bind primary" bindtap="onBindHint">如何绑定</button>
        </block>
      </view>
    </view>
  </block>

  <!-- 捐献榜单 -->
  <block wx:if="{{tab === 'donations'}}">
    <view class="panel form-panel">
      <text class="panel-title">添加捐献记录</text>
      <view class="type-row">
        <text class="type-label">榜单</text>
        <view class="type-btns">
          <text class="type-btn {{newDonation.type === 'hall' ? 'on' : ''}}" bindtap="onDonationTypeChange" data-type="hall">祠堂捐献</text>
          <text class="type-btn {{newDonation.type === 'qingming' ? 'on' : ''}}" bindtap="onDonationTypeChange" data-type="qingming">清明祭祖</text>
          <text class="type-btn {{newDonation.type === 'other' ? 'on' : ''}}" bindtap="onDonationTypeChange" data-type="other">其他贡献</text>
        </view>
      </view>
      <view class="field">
        <text class="label">姓名</text>
        <input class="input" placeholder="捐献人姓名" value="{{newDonation.name}}" bindinput="onDonationNameInput" />
      </view>
      <view class="field">
        <text class="label">金额/贡献</text>
        <input class="input" placeholder="如：50000元" value="{{newDonation.amount}}" bindinput="onDonationAmountInput" />
      </view>
      <view class="field">
        <text class="label">日期</text>
        <input class="input" placeholder="如：2024-01-15" value="{{newDonation.date}}" bindinput="onDonationDateInput" />
      </view>
      <view class="field">
        <text class="label">说明</text>
        <input class="input" placeholder="备注" value="{{newDonation.note}}" bindinput="onDonationNoteInput" />
      </view>
      <button class="btn-primary" bindtap="onAddDonation">添加记录</button>
    </view>

    <view class="campaign" wx:if="{{hallDonationsList.length > 0}}">
      <view class="campaign-head">
        <text class="campaign-title">祠堂捐献</text>
        <text class="campaign-meta">共 {{hallDonationsList.length}} 笔记录</text>
      </view>
      <view class="campaign-body">
        <view class="entry" wx:for="{{hallDonationsList}}" wx:key="index">
          <text class="who">{{item.name}}</text>
          <text class="amt">{{item.amount}}</text>
        </view>
      </view>
    </view>

    <view class="campaign" wx:if="{{qingmingDonationsList.length > 0}}">
      <view class="campaign-head">
        <text class="campaign-title">清明祭祖</text>
        <text class="campaign-meta">共 {{qingmingDonationsList.length}} 笔记录</text>
      </view>
      <view class="campaign-body">
        <view class="entry" wx:for="{{qingmingDonationsList}}" wx:key="index">
          <text class="who">{{item.name}}</text>
          <text class="amt">{{item.amount}}</text>
        </view>
      </view>
    </view>

    <view class="campaign" wx:if="{{otherHonorsList.length > 0}}">
      <view class="campaign-head">
        <text class="campaign-title">其他重大贡献</text>
        <text class="campaign-meta">共 {{otherHonorsList.length}} 笔记录</text>
      </view>
      <view class="campaign-body">
        <view class="entry" wx:for="{{otherHonorsList}}" wx:key="index">
          <text class="who">{{item.name}}</text>
          <text class="amt">{{item.amount}}</text>
        </view>
      </view>
    </view>
  </block>

  <!-- 家族活动 -->
  <block wx:if="{{tab === 'activities'}}">
    <view class="moment-toolbar">
      <button class="btn-publish" bindtap="onOpenComposer">＋ 发布</button>
    </view>
    <view wx:if="{{moments.length === 0}}" class="empty-hint">暂无动态，管理员可发布活动图文。</view>
    <view class="moment-card" wx:for="{{moments}}" wx:key="id">
      <view class="moment-head">
        <view class="avatar">{{item.avatarLetter}}</view>
        <view class="who">
          <text class="name">{{item.author_name}}</text>
          <text class="meta">{{item.displayTime}}</text>
        </view>
      </view>
      <text class="moment-text">{{item.content}}</text>
      <view class="photos" wx:if="{{item.image_urls && item.image_urls.length}}">
        <image class="ph" wx:for="{{item.image_urls}}" wx:for-item="src" wx:key="*this" src="{{src}}" mode="aspectFill" />
      </view>
    </view>
  </block>

  <!-- 发布半屏 -->
  <view class="composer-mask" wx:if="{{composerOpen}}" bindtap="onCloseComposer">
    <view class="composer-sheet" catchtap="preventBubble">
      <view class="composer-bar">
        <text class="ghost-btn" bindtap="onCloseComposer">取消</text>
        <text class="composer-title">发布活动</text>
        <text class="primary-btn" bindtap="onPublishMoment">发表</text>
      </view>
      <textarea class="composer-input" placeholder="分享文字…（图片上传可在后续版本接入）" value="{{composerText}}" bindinput="onComposerInput" maxlength="2000" auto-focus />
    </view>
  </view>
</view>
