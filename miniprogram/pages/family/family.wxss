.container { min-height: 100vh; background: #f5f0eb; padding-bottom: 30px; }
.page-header { background: #8B4513; color: white; padding: 20px; border-radius: 0 0 20px 20px; margin-bottom: 0; }
.page-title { display: block; font-size: 20px; font-weight: bold; }

.tab-bar { display: flex; background: white; border-bottom: 1px solid #eee; margin-bottom: 16px; }
.tab { flex: 1; text-align: center; padding: 14px; font-size: 15px; color: #999; border-bottom: 2px solid transparent; }
.tab.active { color: #8B4513; border-bottom-color: #8B4513; font-weight: bold; }

.section { padding: 0 16px; }

.info-card, .add-donation-card { background: white; border-radius: 12px; padding: 18px; margin-bottom: 16px; }
.info-title { font-size: 16px; font-weight: bold; color: #8B4513; margin-bottom: 16px; }

.form-item { margin-bottom: 14px; }
.form-label { display: block; font-size: 13px; color: #999; margin-bottom: 6px; }
.form-input { border: 1px solid #ddd; border-radius: 8px; padding: 9px 12px; font-size: 14px; width: 100%; box-sizing: border-box; }
.form-textarea { border: 1px solid #ddd; border-radius: 8px; padding: 9px 12px; font-size: 14px; width: 100%; box-sizing: border-box; min-height: 70px; }
.form-textarea.auto-height { min-height: 100px; }

.btn-save { background: #8B4513; color: white; border-radius: 25px; font-size: 15px; margin-top: 10px; }
.btn-add { background: #8B4513; color: white; border-radius: 25px; font-size: 15px; margin-top: 10px; }

/* 捐献榜单 */
.donation-type-row { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; flex-wrap: wrap; }
.type-label { font-size: 13px; color: #999; }
.type-btns { display: flex; gap: 8px; flex-wrap: wrap; }
.type-btn { font-size: 13px; padding: 4px 12px; border-radius: 15px; background: #f0ebe5; color: #999; }
.type-btn.active { background: #8B4513; color: white; }

.donation-list { background: white; border-radius: 12px; padding: 16px; margin-bottom: 16px; }
.donation-list-title { font-size: 15px; font-weight: bold; color: #8B4513; margin-bottom: 12px; }
.donation-item { display: flex; justify-content: space-between; align-items: flex-start; padding: 12px 0; border-bottom: 1px dashed #eee; }
.donation-item:last-child { border-bottom: none; }
.donation-left { flex: 1; }
.donation-name { display: block; font-size: 15px; font-weight: bold; color: #333; margin-bottom: 3px; }
.donation-note { display: block; font-size: 13px; color: #999; }
.donation-right { text-align: right; flex-shrink: 0; margin-left: 16px; }
.donation-amount { display: block; font-size: 15px; color: #8B4513; font-weight: bold; }
.donation-date { display: block; font-size: 12px; color: #bbb; margin-top: 3px; }
