.page-root {
  min-height: 100vh;
  background: #f5f0eb;
  padding-bottom: calc(24px + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.family-head {
  background: #8b4513;
  color: #fff;
  padding: 24rpx 32rpx 0;
  border-radius: 0 0 56rpx 56rpx;
  margin-bottom: 24rpx;
}

.family-head-text {
  padding-bottom: 16rpx;
}

.family-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 0.02em;
}

.family-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  opacity: 0.88;
}

.tabs-in-head {
  display: flex;
  margin: 16rpx -32rpx 0;
  padding: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow: hidden;
  border-bottom: 1rpx solid #eee;
}

.tabs-in-head .tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 8rpx;
  font-size: 26rpx;
  color: #78716c;
  box-sizing: border-box;
}

.tabs-in-head .tab.active {
  color: #8b4513;
  font-weight: 700;
  border-bottom: 4rpx solid #8b4513;
  margin-bottom: -2rpx;
}

.panel {
  margin: 0 24rpx 24rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 1rpx solid #e7e0d7;
}

.form-panel .panel-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #8b4513;
  margin-bottom: 24rpx;
}

.field {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #78716c;
  margin-bottom: 10rpx;
  font-weight: 600;
}

.input,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #e7e0d7;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  background: #fafaf9;
}

.textarea {
  min-height: 140rpx;
}

.textarea.tall {
  min-height: 200rpx;
}

.btn-primary {
  margin-top: 12rpx;
  background: #8b4513 !important;
  color: #fff !important;
  border-radius: 999rpx !important;
  font-size: 30rpx !important;
  font-weight: 600;
}

.btn-primary::after {
  border: none;
}

.bind-card {
  margin-top: 36rpx;
  padding-top: 28rpx;
  border-top: 1rpx dashed #e7e0d7;
}

.bind-title {
  display: block;
  font-size: 24rpx;
  font-weight: 700;
  color: #78716c;
  letter-spacing: 0.08em;
  margin-bottom: 16rpx;
}

.bind-line {
  display: block;
  font-size: 30rpx;
  color: #1c1917;
  line-height: 1.5;
}

.bind-line.muted {
  color: #78716c;
}

.bind-line .em {
  color: #8b4513;
  font-weight: 700;
}

.bind-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.btn-bind {
  flex: 1;
  min-width: 200rpx;
  font-size: 26rpx !important;
  padding: 16rpx !important;
  border-radius: 999rpx !important;
  font-weight: 600;
}

.btn-bind::after {
  border: none;
}

.btn-bind.primary {
  background: #8b4513 !important;
  color: #fff !important;
}

.btn-bind.ghost {
  background: #f5f0eb !important;
  color: #44403c !important;
  border: 1rpx solid #e7e0d7 !important;
}

.btn-bind.danger {
  background: #fff !important;
  color: #991b1b !important;
  border: 1rpx solid #fecaca !important;
}

.type-row {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 24rpx;
  flex-wrap: wrap;
}

.type-label {
  font-size: 26rpx;
  color: #78716c;
  flex-shrink: 0;
  padding-top: 8rpx;
}

.type-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.type-btn {
  font-size: 24rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #f5f0eb;
  color: #78716c;
}

.type-btn.on {
  background: #8b4513;
  color: #fff;
}

.campaign {
  margin: 0 24rpx 24rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 1rpx solid #e7e0d7;
  overflow: hidden;
}

.campaign-head {
  padding: 24rpx 28rpx;
  background: linear-gradient(180deg, #f0ebe3 0%, #fff 100%);
  border-bottom: 1rpx solid #e7e0d7;
}

.campaign-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1c1917;
}

.campaign-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #78716c;
}

.campaign-body {
  padding: 8rpx 0;
}

.entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 28rpx;
  border-bottom: 1rpx solid #f0ebe3;
}

.entry:last-child {
  border-bottom: none;
}

.entry .who {
  font-size: 28rpx;
  color: #1c1917;
}

.entry .amt {
  font-size: 28rpx;
  font-weight: 700;
  color: #8b4513;
}

.moment-toolbar {
  display: flex;
  justify-content: flex-end;
  padding: 0 24rpx 16rpx;
}

.btn-publish {
  font-size: 26rpx !important;
  padding: 14rpx 28rpx !important;
  border-radius: 999rpx !important;
  background: #fff !important;
  color: #8b4513 !important;
  border: 1rpx solid #e7e0d7 !important;
  font-weight: 600;
}

.btn-publish::after {
  border: none;
}

.empty-hint {
  margin: 48rpx 40rpx;
  text-align: center;
  font-size: 26rpx;
  color: #a8a29e;
}

.moment-card {
  margin: 0 24rpx 24rpx;
  padding: 28rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 1rpx solid #e7e0d7;
}

.moment-head {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  background: rgba(139, 69, 19, 0.12);
  color: #8b4513;
  font-size: 36rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.moment-head .who {
  flex: 1;
  min-width: 0;
}

.moment-head .name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1c1917;
}

.moment-head .meta {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #78716c;
}

.moment-text {
  font-size: 28rpx;
  line-height: 1.55;
  color: #292524;
}

.photos {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.ph {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #f5f0eb;
}

.composer-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.48);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.composer-sheet {
  width: 100%;
  background: #faf8f5;
  border-radius: 32rpx 32rpx 0 0;
  padding: 24rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.composer-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #e7e0d7;
}

.composer-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1c1917;
}

.ghost-btn {
  font-size: 28rpx;
  color: #78716c;
  padding: 8rpx;
}

.primary-btn {
  font-size: 28rpx;
  color: #8b4513;
  font-weight: 700;
  padding: 8rpx;
}

.composer-input {
  width: 100%;
  min-height: 220rpx;
  box-sizing: border-box;
  border: 1rpx solid #e7e0d7;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
}
