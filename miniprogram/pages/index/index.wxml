<view class="container">
  <view class="header-bar">
    <text class="page-title">我的家族</text>
    <text class="page-sub">{{families.length}} 个家族</text>
  </view>

  <view class="content">
    <!-- 加载中 -->
    <view wx:if="{{isLoading && families.length === 0}}" class="loading-state">
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 家族列表 -->
    <view wx:if="{{families.length > 0}}" class="family-list">
      <view wx:for="{{families}}" wx:key="id" class="family-card" bindtap="onFamilyTap" data-id="{{item.id}}" data-name="{{item.name}}">
        <view class="family-icon">📖</view>
        <view class="family-info">
          <text class="family-name">{{item.name}}</text>
          <text wx:if="{{item.hall_name}}" class="family-hall">堂号：{{item.hall_name}}</text>
          <text class="family-meta">{{item.surname || ''}}氏 · {{item.member_count || 0}} 人</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:else class="empty-state">
      <text class="empty-icon">📒</text>
      <text class="empty-text">还没有家族</text>
      <text class="empty-hint">创建一个属于你的家族吧</text>
    </view>

    <!-- 创建按钮 -->
    <button class="btn-create" bindtap="onCreateFamily">+ 创建新家族</button>
  </view>
</view>
