<view class="container">
  <view class="title">我的家族</view>

  <view wx:if="{{loading}}" class="loading">加载中...</view>

  <block wx:elif="{{families.length > 0}}">
    <view wx:for="{{families}}" wx:key="id" class="card" bindtap="goToTree" data-id="{{item.id}}">
      <view class="family-name">{{item.name}}</view>
      <view class="family-info text-muted">
        {{item.member_count || 0}} 人 · 创建于 {{item.created_at}}
      </view>
    </view>
  </block>

  <view wx:else class="empty">
    <text>暂无家族，点击下方按钮创建</text>
  </view>

  <button class="btn-primary" bindtap="createFamily">创建家族</button>
</view>