.container { min-height: 100vh; background: #f5f0eb; }
.header-bar { background: #8B4513; color: white; padding: 20px 20px 30px; border-radius: 0 0 20px 20px; }
.page-title { display: block; font-size: 24px; font-weight: bold; margin-bottom: 4px; }
.page-sub { display: block; font-size: 12px; opacity: 0.8; }
.content { padding: 20px; }
.family-list { margin-bottom: 20px; }
.family-card { background: white; border-radius: 12px; padding: 16px; margin-bottom: 12px; display: flex; align-items: center; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.family-icon { font-size: 32px; margin-right: 14px; }
.family-info { flex: 1; }
.family-name { display: block; font-size: 17px; font-weight: bold; color: #333; margin-bottom: 3px; }
.family-hall { display: block; font-size: 13px; color: #8B4513; margin-bottom: 2px; }
.family-meta { display: block; font-size: 13px; color: #999; }
.arrow { font-size: 22px; color: #ccc; }
.loading-state { text-align: center; padding: 60px 20px; }
.loading-text { font-size: 15px; color: #999; }
.empty-state { text-align: center; padding: 60px 20px; }
.empty-icon { display: block; font-size: 60px; margin-bottom: 15px; }
.empty-text { display: block; font-size: 18px; color: #666; margin-bottom: 8px; }
.empty-hint { display: block; font-size: 14px; color: #999; }
.btn-create { background: #8B4513; color: white; border-radius: 25px; font-size: 16px; padding: 12px; margin-top: 10px; }
