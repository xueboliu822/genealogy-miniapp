.container { padding: 80px 40px; background: linear-gradient(135deg, #8B4513 0%, #D2691E 100%); min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.header { text-align: center; margin-bottom: 80px; }
.app-name { display: block; font-size: 40px; font-weight: bold; color: white; margin-bottom: 10px; }
.app-desc { display: block; font-size: 16px; color: rgba(255,255,255,0.8); }
.btn-login { background: white; color: #8B4513; border-radius: 25px; width: 80%; font-weight: bold; margin-bottom: 15px; }
.btn-skip { background: transparent; color: white; border: 1px solid rgba(255,255,255,0.5); border-radius: 25px; width: 80%; }
