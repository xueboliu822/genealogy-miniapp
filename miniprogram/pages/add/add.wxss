.container { min-height: 100vh; background: #f5f0eb; padding: 20px; }
.mode-tabs { display: flex; background: white; border-radius: 12px; padding: 4px; margin-bottom: 20px; }
.tab { flex: 1; text-align: center; padding: 10px; border-radius: 8px; font-size: 15px; color: #999; }
.tab.active { background: #8B4513; color: white; font-weight: bold; }
.form { background: white; border-radius: 12px; padding: 20px; }
.form-item { margin-bottom: 18px; }
.form-label { display: block; font-size: 14px; color: #666; margin-bottom: 6px; }
.form-input { border: 1px solid #ddd; border-radius: 8px; padding: 10px 12px; font-size: 15px; }
radio-group { display: flex; gap: 20px; }
.radio-item { font-size: 15px; }
.picker-value { border: 1px solid #ddd; border-radius: 8px; padding: 10px 12px; font-size: 15px; color: #999; }
.form-textarea { border: 1px solid #ddd; border-radius: 8px; padding: 10px 12px; font-size: 15px; width: 100%; box-sizing: border-box; min-height: 80px; }
.form-hint { display: block; font-size: 12px; color: #aaa; margin-top: 4px; }
.btn-submit { background: #8B4513; color: white; border-radius: 25px; font-size: 16px; margin-top: 10px; }
