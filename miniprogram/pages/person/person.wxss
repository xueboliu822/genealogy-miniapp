.container { min-height: 100vh; background: #f5f0eb; padding: 20px; }
.person-card { background: #8B4513; color: white; border-radius: 16px; padding: 30px; text-align: center; margin-bottom: 20px; }
.avatar { font-size: 60px; margin-bottom: 10px; }
.person-name { display: block; font-size: 26px; font-weight: bold; margin-bottom: 6px; }
.person-gen { display: block; font-size: 14px; opacity: 0.8; }
.info-list { background: white; border-radius: 12px; overflow: hidden; margin-bottom: 20px; }
.info-item { padding: 15px 18px; border-bottom: 1px solid #f0f0f0; display: flex; }
.info-item:last-child { border-bottom: none; }
.info-label { font-size: 14px; color: #999; width: 80px; flex-shrink: 0; }
.info-value { font-size: 14px; color: #333; flex: 1; }
.actions { }
.btn-edit { background: white; color: #8B4513; border: 1px solid #8B4513; border-radius: 25px; }

/* 编辑表单样式 */
.edit-form { background: white; border-radius: 16px; padding: 20px; }
.form-title { font-size: 18px; font-weight: bold; color: #8B4513; margin-bottom: 20px; text-align: center; }
.form-item { margin-bottom: 18px; }
.form-label { display: block; font-size: 14px; color: #666; margin-bottom: 8px; }
.form-input { border: 1px solid #ddd; border-radius: 8px; padding: 10px 12px; font-size: 14px; }
.form-picker { border: 1px solid #ddd; border-radius: 8px; padding: 10px 12px; font-size: 14px; background: #fafafa; }
.form-textarea { border: 1px solid #ddd; border-radius: 8px; padding: 10px 12px; font-size: 14px; width: 100%; box-sizing: border-box; min-height: 80px; }
.form-actions { display: flex; gap: 12px; margin-top: 24px; }
.btn-cancel { flex: 1; background: #f5f5f5; color: #666; border-radius: 25px; }
.btn-save { flex: 1; background: #8B4513; color: white; border-radius: 25px; }
