.container { min-height: 100vh; background: #f5f0eb; padding: 20px; }

/* 头像区域 */
.avatar-section { text-align: center; margin-bottom: 16px; }
.avatar {
  width: 90px; height: 90px; border-radius: 50%;
  background: #e8d5c4; display: inline-flex; align-items: center; justify-content: center;
  font-size: 48px; overflow: hidden; margin: 0 auto 8px;
}
.avatar-img { width: 100%; height: 100%; object-fit: cover; }
.avatar-deceased { filter: grayscale(100%); }
.avatar-placeholder { line-height: 90px; }
.avatar-tip { font-size: 12px; color: #aaa; }

/* 人物卡片 */
.person-card { background: #8B4513; color: white; border-radius: 16px; padding: 24px; text-align: center; margin-bottom: 16px; }
.person-name-row { display: flex; align-items: center; justify-content: center; gap: 8px; margin-bottom: 6px; }
.person-name { font-size: 26px; font-weight: bold; }
.gen-name { font-size: 16px; opacity: 0.85; background: rgba(255,255,255,0.2); padding: 2px 10px; border-radius: 10px; }
.person-gen { display: block; font-size: 14px; opacity: 0.8; margin-bottom: 8px; }
.life-status { display: flex; align-items: center; justify-content: center; gap: 12px; flex-wrap: wrap; }
.status-alive { font-size: 13px; color: #90EE90; }
.status-deceased { font-size: 13px; color: #ccc; }
.life-year { font-size: 13px; opacity: 0.8; }

/* 信息列表 */
.info-list { background: white; border-radius: 12px; overflow: hidden; margin-bottom: 16px; }
.info-item { padding: 14px 18px; border-bottom: 1px solid #f0f0f0; display: flex; align-items: flex-start; }
.info-item:last-child { border-bottom: none; }
.info-label { font-size: 14px; color: #999; width: 80px; flex-shrink: 0; margin-top: 2px; }
.info-value { font-size: 14px; color: #333; flex: 1; }

/* 评价区域 */
.eval-section { background: white; border-radius: 12px; padding: 16px; margin-bottom: 16px; }
.eval-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.eval-title { font-size: 16px; font-weight: bold; color: #8B4513; }
.eval-count { font-size: 13px; color: #aaa; }
.eval-item { padding: 10px 0; border-bottom: 1px dashed #eee; }
.eval-item:last-of-type { border-bottom: none; }
.eval-content { display: block; font-size: 14px; color: #333; line-height: 1.6; }
.eval-date { display: block; font-size: 12px; color: #bbb; margin-top: 4px; text-align: right; }
.eval-input-row { display: flex; gap: 8px; margin-top: 12px; align-items: center; }
.eval-input { flex: 1; border: 1px solid #ddd; border-radius: 20px; padding: 8px 14px; font-size: 14px; }
.eval-btn { background: #8B4513; color: white; border-radius: 20px; font-size: 14px; padding: 0 16px; height: 36px; line-height: 36px; }

/* 操作按钮 */
.actions { }
.btn-edit { background: white; color: #8B4513; border: 1px solid #8B4513; border-radius: 25px; }

/* 编辑表单 */
.edit-form { background: white; border-radius: 16px; padding: 20px; }
.form-title { font-size: 18px; font-weight: bold; color: #8B4513; margin-bottom: 20px; text-align: center; }
.form-item { margin-bottom: 16px; }
.form-label { display: block; font-size: 14px; color: #666; margin-bottom: 6px; }
.form-input { border: 1px solid #ddd; border-radius: 8px; padding: 10px 12px; font-size: 14px; width: 100%; box-sizing: border-box; }
.form-picker { border: 1px solid #ddd; border-radius: 8px; padding: 10px 12px; font-size: 14px; background: #fafafa; }
.form-textarea { border: 1px solid #ddd; border-radius: 8px; padding: 10px 12px; font-size: 14px; width: 100%; box-sizing: border-box; min-height: 80px; }
.radio-item { font-size: 14px; margin-right: 16px; }
.form-actions { display: flex; gap: 12px; margin-top: 20px; }
.btn-cancel { flex: 1; background: #f5f5f5; color: #666; border-radius: 25px; }
.btn-save { flex: 1; background: #8B4513; color: white; border-radius: 25px; }
