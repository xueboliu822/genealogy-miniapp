.person-card {
  padding: 40rpx;
}

.header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  background: #8B4513;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-right: 30rpx;
}

.avatar.female {
  background: #e07a5f;
}

.info .name {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.meta {
  font-size: 28rpx;
}

.section {
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid #eee;
}

.section-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.relation-item {
  padding: 20rpx 0;
  font-size: 32rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}