<view class="container">
  <view class="person-card">
    <view class="avatar">{{person.gender === 'M' ? '👨' : person.gender === 'F' ? '👩' : '👤'}}</view>
    <text class="person-name">{{person.name}}</text>
    <text class="person-gen">第 {{person.generation_num}} 代</text>
  </view>

  <view class="info-list">
    <view class="info-item">
      <text class="info-label">性别</text>
      <text class="info-value">{{person.gender === 'M' ? '男' : person.gender === 'F' ? '女' : '其他'}}</text>
    </view>
    <view class="info-item" wx:if="{{person.birth_year}}">
      <text class="info-label">出生年份</text>
      <text class="info-value">{{person.birth_year}}</text>
    </view>
    <view class="info-item" wx:if="{{person.bio}}">
      <text class="info-label">简介</text>
      <text class="info-value">{{person.bio}}</text>
    </view>
    <view class="info-item" wx:if="{{person.father_name}}">
      <text class="info-label">父亲</text>
      <text class="info-value">{{person.father_name}}</text>
    </view>
  </view>

  <view class="actions">
    <button class="btn-edit" bindtap="onEdit">编辑</button>
  </view>
</view>
